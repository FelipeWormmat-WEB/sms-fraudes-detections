# Copy this file to .env and fill real values.

# PostgreSQL
POSTGRES_USER=user
POSTGRES_PASSWORD=password
POSTGRES_DB=smsdb
POSTGRES_HOST=db
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://user:password@db:5432/smsdb

# Services
CLASSIFICATION_URL=http://classification-service:8080
LLM_SERVICE_URL=http://llm-service:8001/analyze

# Security
SECRET_KEY=change-in-production
ADMIN_API_KEY=change-admin-in-production
ENFORCE_API_KEY=true

# App config
LOG_LEVEL=INFO
ENVIRONMENT=development
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
HYBRID_LLM_THRESHOLD=0.7

# LLM provider keys (never commit real values)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
MISTRAL_API_KEY=
HUGGING_FACE_HUB_TOKEN=
